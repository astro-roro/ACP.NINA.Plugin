<ResourceDictionary
    x:Class="ACP.NINA.Plugin.Dockables.AcpDockableTemplate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ACP.NINA.Plugin.Dockables">

    <DataTemplate DataType="{x:Type local:AcpDockableVM}">
        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: connection status -->
            <Border Grid.Row="0"
                    Padding="6,4"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#888" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="#4CAF50" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                            <Setter Property="Fill" Value="#F44336" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="24" Height="24"
                            Command="{Binding RefreshCommand}"
                            ToolTip="Refresh plans from ACP"
                            Content="⟳" />
                </Grid>
            </Border>

            <!-- Row 1: plans header -->
            <TextBlock Grid.Row="1"
                       Margin="0,8,0,4"
                       FontWeight="Bold">
                <Run Text="Plans (" /><Run Text="{Binding Plans.Count, Mode=OneWay}" /><Run Text=")" />
            </TextBlock>

            <!-- Row 2: plans list -->
            <Border Grid.Row="2"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <ListBox ItemsSource="{Binding Plans}"
                         SelectedItem="{Binding SelectedPlan}"
                         HorizontalContentAlignment="Stretch"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,6,4,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{Binding ProjectName}"
                                           FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding State}"
                                           FontSize="11"
                                           Opacity="0.7" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Margin="8,2,0,0"
                                           FontSize="11"
                                           Opacity="0.85">
                                    <Run Text="{Binding TargetName, Mode=OneWay}" /><Run Text=" · " /><Run Text="{Binding FilterSummary, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                           Margin="8,2,0,0"
                                           FontSize="11"
                                           Opacity="0.65">
                                    <Run Text="{Binding MosaicShort, Mode=OneWay}" /><Run Text=" · " /><Run Text="{Binding GearShort, Mode=OneWay}" />
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Row 3: selected plan details -->
            <Border Grid.Row="3"
                    Margin="0,8,0,0"
                    Padding="6,4"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Visibility="{Binding HasSelection, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{Binding SelectedPlanSummary}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedPlanCoordinates}"
                               FontSize="11"
                               Opacity="0.85"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <!-- Row 4: action buttons -->
            <StackPanel Grid.Row="4"
                        Margin="0,8,0,0"
                        Orientation="Vertical">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Height="32"
                            Command="{Binding PushToFramingCommand}"
                            Content="Push to Framing" />
                    <Button Grid.Column="2"
                            Height="32"
                            Command="{Binding SyncAllToTsCommand}"
                            Content="Sync All to TS" />
                </Grid>
                <TextBlock Margin="0,4,0,0"
                           FontSize="11"
                           Opacity="0.7">
                    <Run Text="Will sync to profile: &quot;" /><Run Text="{Binding ActiveProfileName, Mode=OneWay}" /><Run Text="&quot;" />
                </TextBlock>
            </StackPanel>

            <!-- Row 5: last action result -->
            <TextBlock Grid.Row="5"
                       Margin="0,8,0,0"
                       FontSize="11"
                       Opacity="0.85"
                       TextWrapping="Wrap"
                       Text="{Binding LastActionResult}" />
        </Grid>
    </DataTemplate>

</ResourceDictionary>
