<ResourceDictionary
    x:Class="ACP.NINA.Plugin.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate x:Key="Astro Coverage Planner (ACP)_Options">
        <StackPanel Margin="0,10,0,10" Orientation="Vertical">

            <TextBlock FontSize="14" FontWeight="Bold" Text="Connection" Margin="0,0,0,6" />

            <Grid Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Server URL:"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         Margin="6,0,6,0"
                         Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Height="24"
                         ToolTip="The HTTP URL of a running ACP instance. Defaults to http://127.0.0.1:5555 (loopback)." />
                <Button Grid.Row="0" Grid.Column="2"
                        Content="Test"
                        Width="60" Height="24"
                        Command="{Binding TestConnectionCommand}" />

                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                           Margin="6,4,0,0"
                           FontSize="11"
                           Opacity="0.75"
                           TextWrapping="Wrap"
                           Text="{Binding ConnectionTestResult}" />

                <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                           Margin="6,8,0,0"
                           FontSize="11"
                           Opacity="0.7"
                           TextWrapping="Wrap"
                           Text="ACP must be running on the same machine as NINA for v1.x. Cross-machine access is planned for v3.0; see the ACP repo for the security model." />
            </Grid>

            <TextBlock FontSize="14" FontWeight="Bold" Text="Behavior" Margin="0,0,0,6" />

            <!-- NINA's CheckBox style renders as a toggle and hides the Content
                 property, so labels live in side-by-side TextBlocks rather than
                 inside the CheckBox. Mirrors NINA core's own options pattern. -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0"
                          IsChecked="{Binding AutoRefreshEnabled}"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" VerticalAlignment="Center">
                    <Run Text="Auto-refresh plans every " /><Run Text="{Binding AutoRefreshSeconds}" /><Run Text=" seconds" />
                </TextBlock>
            </Grid>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0"
                          IsChecked="{Binding ConfirmBeforeTsSync}"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="Confirm before Sync to TS" />
            </Grid>

        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
